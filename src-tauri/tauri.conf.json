{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Private Assistant",
  "version": "0.1.0",
  "identifier": "gg.sysinfo.automate",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Private Assistant",
        "width": 480,
        "height": 740,
        "minWidth": 420,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": false,
        "backgroundColor": "#0c0a10"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: https://media.valorant-api.com; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png"],
    "resources": ["../private", "../tracex"]
  }
}
